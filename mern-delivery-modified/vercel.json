{
  "buildCommand": "cd artifacts/food-delivery && npx vite build --config vite.config.ts",
  "outputDirectory": "artifacts/food-delivery/dist/public",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/((?!assets/|.*\\..*).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
